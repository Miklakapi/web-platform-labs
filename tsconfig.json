{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "useDefineForClassFields": false,
        "lib": ["ES2020", "DOM", "DOM.Iterable"]
    },
    "include": ["src/**/*.ts"]
}
